# Copy to .env and fill in values.
# For device testing, do NOT use localhost — use your PC LAN IP.

EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:3040
EXPO_PUBLIC_API_WITH_CREDENTIALS=true
EXPO_PUBLIC_WEB_APP_URL=http://192.168.x.x:3000
EXPO_PUBLIC_TRUSTED_WEB_ORIGINS=http://192.168.x.x:3000
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=<google-web-client-id>
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=<google-ios-client-id>
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=<google-android-client-id>
EXPO_PUBLIC_TOKEN_STORAGE_KEY=THREADLY_ACCESS_TOKEN
EXPO_PUBLIC_USER_STORAGE_KEY=THREADLY_USER

# Expo push tokens require the Expo/EAS project ID, not an FCM sender ID.
# Get this from `eas project:info` or the Expo dashboard after the app is linked.
EXPO_PUBLIC_EAS_PROJECT_ID= 7a977582-8fd7-4eb5-b652-e914734702d5
